# ──────────────────────────────────────────────────────────────────────────
# OpenAlt — environment variables
# Copy to .env.local for local dev. In Vercel, add these in Project Settings.
# Only DATABASE_URL is strictly required for the site to render data.
# Clerk / Stripe / Plausible features degrade gracefully when their keys absent.
# ──────────────────────────────────────────────────────────────────────────

# Public base URL (no trailing slash). Used for canonical URLs, sitemap, OG, Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Neon Postgres) ────────────────────────────────────────────────
# Neon: use the POOLED connection string. Works with any standard Postgres too.
# Example (Neon):  postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
# Example (local): postgresql://postgres:postgres@localhost:5432/openalt
DATABASE_URL=

# ── Clerk (auth for /submit and /admin only; browsing needs no login) ───────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Comma-separated list of admin email addresses allowed into /admin.
ADMIN_EMAILS=

# ── Stripe (self-serve "Featured" placements) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for the monthly "Featured" subscription (create a recurring Price in Stripe).
NEXT_PUBLIC_STRIPE_FEATURED_PRICE_ID=

# ── GitHub (ingestion pipeline) ─────────────────────────────────────────────
# A classic or fine-grained PAT with public-repo read access. Raises the GitHub
# API rate limit from ~10 to ~30 search req/min and 5000 req/hr overall.
GITHUB_TOKEN=

# ── Anthropic Claude (ingestion extraction) ─────────────────────────────────
# Enables accurate `replaces` / self-host difficulty / feature-gap extraction.
# Without it, the ingester falls back to a deterministic heuristic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Hosting-platform affiliate / referral codes (monetization) ──────────────
# Appended to the "one-click deploy" links so the highest-intent clicks are
# monetized. All optional — deploy links still work without them.
RAILWAY_REFERRAL_CODE=
COOLIFY_AFFILIATE_REF=
PIKAPODS_AFFILIATE_REF=
ELESTIO_AFFILIATE_REF=
DIGITALOCEAN_REFERRAL_CODE=

# ── Plausible analytics (optional) ──────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Ingestion tuning (optional) ─────────────────────────────────────────────
# Max candidate repos to process per source per run.
INGEST_MAX_PER_SOURCE=80
# Minimum GitHub stars for a project to be considered.
INGEST_MIN_STARS=200
